*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# Xcode Swift Package Manager local resolution (machine-specific)
**/xcshareddata/swiftpm/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Node
node_modules/

# Backend
backend/venv/
backend/__pycache__/
backend/uploads/

# Environment & secrets (never commit real values)
.env
.env.local
.env.*.local
backend/.env
secrets.yml

# Examples are safe to commit
!.env.example
!backend/.env.example
!secrets.yml.example

# Private keys, keystores, provisioning
*.pem
*.p8
*.p12
*.jks
*.keystore
*.mobileprovision

# iOS signing bundle (keep ExportOptions.plist only)
ios_signing/*
!ios_signing/ExportOptions.plist

# Repo-root signing artifacts
gojo_*_key.pem
gojo_*_csr.pem
gojo-mac-key.pem
codemagic.keystore
my-release-key.jks
ocsp_check/

# Misc local artifacts
gojocalories_backup.zip
.agents/
