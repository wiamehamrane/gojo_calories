# ─────────────────────────────────────────────────────────────
# Backend API — copy to `backend/.env`:
#   cp backend/.env.example backend/.env
# Then edit values. Never commit your real `.env`.
# ─────────────────────────────────────────────────────────────

# ── Required (local boot) ────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gojocalories
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000
REDIS_URL=redis://localhost:6379/0

# true = local/dev behaviours (do not use in production)
DEV_MODE=true

# Independent from DEV_MODE. true = activate coach listing without store IAP.
SKIP_COACH_PAYMENT=false

# ── File uploads ─────────────────────────────────────────────
# Local disk uploads when AWS is not configured (good for first-time setup)
ALLOW_LOCAL_UPLOADS=true

# Leave empty / omit for local uploads, or fill for S3:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# ── AI / food vision & events search ─────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-5.4-mini
# FOODDATA_CENTRAL_API_KEY=
# GEMINI_API_KEY=

# ── Auth / Sign-In ───────────────────────────────────────────
# GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# ── Apple / Google IAP (needed for real subscriptions) ───────
APPLE_SHARED_SECRET=
# APPLE_APP_ID=
# GOOGLE_PLAY_PACKAGE_NAME=com.gojocalories.gojocalories
# GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ── Stripe (optional — web/admin payments) ───────────────────
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_MONTHLY=
# STRIPE_PRICE_SIX_MONTH=
# STRIPE_PRICE_YEARLY=
# STRIPE_PRICE_CLAN_ADDON_MONTHLY=
# STRIPE_PRICE_CLAN_ADDON_SIX_MONTH=
# STRIPE_PRICE_CLAN_ADDON_YEARLY=
# STRIPE_REFERRAL_COUPON_ID=

# ── Push notifications (optional) ────────────────────────────
# ONESIGNAL_APP_ID=
# ONESIGNAL_REST_API_KEY=
# ADMIN_API_KEY=change-me-in-production
# SMART_NOTIF_ENABLED=true
# SMART_NOTIF_LOCAL_HOURS=10,12,14,16,18,20
# SMART_NOTIF_TZ_OFFSET_MIN=60

# ── Email (optional — defaults to SES if AWS keys are set) ───
# EMAIL_PROVIDER=ses
# SES_SENDER_EMAIL=noreply@gojocalories.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# ── Misc (optional) ──────────────────────────────────────────
# LOG_LEVEL=INFO
# SHARE_LINK_BASE=https://gojocalories.com/share
# DB_SECRET=
# WIPE_DB=false
