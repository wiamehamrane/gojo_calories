# ─────────────────────────────────────────────────────────────
# Flutter app — copy to `.env` at the repo root:
#   cp .env.example .env
# Then edit values. Never commit your real `.env`.
# ─────────────────────────────────────────────────────────────

# prod | dev
# - prod → API_URL_PROD
# - dev  → simulator / emulator / device URL (see below)
APP_ENV=dev

API_URL_PROD=https://api.gojocalories.com/api/

# ── Used when APP_ENV=dev ────────────────────────────────────
# iOS Simulator → Mac localhost
API_URL_DEV_SIMULATOR=http://127.0.0.1:8000/api/
# Android Emulator → special alias to the host Mac (NOT 127.0.0.1)
API_URL_DEV_EMULATOR=http://10.0.2.2:8000/api/
# Physical phone on same Wi‑Fi — replace with your Mac LAN IP
#   macOS: System Settings → Network, or: ipconfig getifaddr en0
API_URL_DEV_DEVICE=http://YOUR_MAC_IP:8000/api/

# Optional force (default: auto): auto | simulator | emulator | device
DEV_API_TARGET=auto

# Coach IAP bypass for local testing only (keep false in real builds)
SKIP_COACH_PAYMENT=false

# Optional Google Sign-In overrides (defaults exist in EnvConfig if omitted)
# GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
# GOOGLE_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com
