# Only change this: prod | dev
APP_ENV=prod

API_URL_PROD=https://api.gojocalories.com/api/

# Used when APP_ENV=dev
API_URL_DEV_SIMULATOR=http://127.0.0.1:8000/api/
API_URL_DEV_EMULATOR=http://10.0.2.2:8000/api/
# Physical phone on same Wi‑Fi — replace with your Mac LAN IP
API_URL_DEV_DEVICE=http://YOUR_MAC_IP:8000/api/

# Optional force: auto | simulator | emulator | device
# DEV_API_TARGET=auto
