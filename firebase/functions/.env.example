# Non-sensitive SMTP config for the OTP email function.
# Copy to functions/.env and fill in. (Sensitive values SMTP_USER, SMTP_PASS,
# OTP_SHARED_SECRET are set as Firebase secrets, NOT here.)

# Examples:
#  SendGrid:  SMTP_HOST=smtp.sendgrid.net   SMTP_PORT=587
#  Mailgun:   SMTP_HOST=smtp.mailgun.org    SMTP_PORT=587
#  Gmail:     SMTP_HOST=smtp.gmail.com      SMTP_PORT=465  (use an app password)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_FROM=GojoCalories <noreply@gojocalories.com>
